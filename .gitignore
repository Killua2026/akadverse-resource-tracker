
# ==========================================
# AkadVerse Resource Tracker - .gitignore
# ==========================================

# 1. Databases (CRITICAL)
# Never push local databases. They cause merge conflicts and leak data.
*.db
*.sqlite
*.sqlite3
tracker_logs.db

# 2. Python Virtual Environments
venv/
.venv/
env/
.env/

# 3. Python Cache and Compiled Files
__pycache__/
*.pyc
*.pyo
*.pyd

# 4. OS and IDE Generated Files
.DS_Store
Thumbs.db
.vscode/
.idea/